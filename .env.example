# Docker build variables
PROJECT_NAME=modxproject
PROJECT_HTTP_PORT=4200
PROJECT_HTTPS_PORT=4201

# Database (Warning: variable names are MariaDB specific ant connot be changed)
MYSQL_DATABASE=modx_db
MYSQL_USER=modx_db
MYSQL_PASSWORD=userpassword
MYSQL_ROOT_PASSWORD=rootpassword

# MODX
MODX_VERSION=3.2.0
#MODX_VERSION=2.8.8
MODX_TABLE_PREFIX=modx_
MODX_HTTP_HOST=localhost
MODX_INSTALL_TYPE=cli
MODX_CMS_ADMIN=developer
MODX_CMS_PASS=modx_pass
MODX_CMS_EMAIL=dummyemail@site.com
MODX_LANGUAGE=ru
MODX_HTTPS_PORT=443
MODX_CONTEXT_WEB_PATH=/var/www/html/
MODX_CONTEXT_WEB_URL=/
MODX_CONTEXT_CONNECTORS_PATH=/var/www/html/connectors/
MODX_CONTEXT_CONNECTORS_URL=/connectors/
MODX_CONTEXT_MANAGER_PATH=/var/www/html/manager/
MODX_CONTEXT_MANAGER_URL=/manager/
MODX_DATABASE_SERVER=mariadb
MODX_DATABASE_CONNECTION_CHARSET=utf8mb4
MODX_DATABASE_CHARSET=utf8mb4
MODX_DATABASE_CHARSET_COLLATION=utf8mb4_unicode_ci
